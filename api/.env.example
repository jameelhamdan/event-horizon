# ── Core / Django ───────────────────────────────────────────────────────────────
SECRET_KEY=change-me
DEBUG=true
ENV_NAME=development
APP_NAME=conflictradar.live
DOMAIN=localhost
CSRF_TRUSTED_ORIGINS=http://localhost
# Sentry (optional)
DSN=

# ── Database (MongoDB) ────────────────────────────────────────────────────────────
# django-mongodb-backend reads the connection string from DATABASES['default']['HOST']
DATABASE_URL=mongodb://root:1234@localhost:27017/radar-live?authSource=admin
DATABASE_NAME=radar-live

# ── Redis (RQ broker + cache + SSE pub/sub) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Task queue ────────────────────────────────────────────────────────────────────
# false → enqueue() runs tasks synchronously in-process (no Redis/worker needed locally)
TASK_QUEUE_ENABLED=false
JOB_TIMEOUT_SECONDS=1800

# ── LLM providers ─────────────────────────────────────────────────────────────────
# Per-provider settings only. The who-uses-what routing lives in settings.LLM_ROUTES
# (a Python dict in settings/base.py), NOT here. Available providers:
#   openrouter, ollama, g4f.

# OpenRouter (https://openrouter.ai) — comma-separated keys rotate round-robin per request
OPENROUTER_API_KEYS=
OPENROUTER_MODELS=openrouter/free

# Ollama (self-hosted, no key) — run `ollama serve` + `ollama pull <model>`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# g4f / gpt4free (registration-free proxy)
# - Local dev (manage.py outside Docker): run `g4f api` → http://localhost:1337/v1
# - Docker Compose: there's a `g4f` service; use http://g4f:1337/v1 in .env.app
G4F_BASE_URL=http://localhost:1337/v1
G4F_MODEL=gpt-4o-mini

# ── Email ─────────────────────────────────────────────────────────────────────────
# EMAIL_PROVIDER: smtp (default) or ses
EMAIL_PROVIDER=smtp
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=newsletter@localhost
NEWSLETTER_BASE_URL=http://localhost

# AWS SES (used when EMAIL_PROVIDER=ses)
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_KEY=
AWS_SES_REGION=us-east-1

# ── Pipeline intervals (minutes) — light/default queue ────────────────────────────
FETCH_INTERVAL_MINUTES=10
PRICE_FETCH_INTERVAL_MINUTES=5
NOTAM_FETCH_INTERVAL_MINUTES=15
EARTHQUAKE_FETCH_INTERVAL_MINUTES=5
EARTHQUAKE_MIN_MAGNITUDE=3.0
FOREX_FETCH_INTERVAL_MINUTES=15

# ── Pipeline intervals (minutes) — heavy/NLP queue (base period, scaled per task) ─
PROCESS_INTERVAL_MINUTES=10
AGGREGATE_INTERVAL_MINUTES=10
TAG_TOPICS_INTERVAL_MINUTES=15
DISCOVER_TOPICS_INTERVAL_MINUTES=30

# ── Cron jobs (hour, UTC) ─────────────────────────────────────────────────────────
TOPICS_REFRESH_HOUR=4
NEWSLETTER_GENERATE_HOUR=6

# ── Topics / discovery tuning ─────────────────────────────────────────────────────
TOPIC_SOURCES_DAYS=30
TOP_LEVEL_SCORE_THRESHOLD=3.0
DISCOVERY_MIN_UNTAGGED_EVENTS=3
DISCOVERY_MAX_CLUSTERS=5

# ── Frontend build args (ui/) ─────────────────────────────────────────────────────
VITE_GA_ID=
VITE_DOMAIN=
VITE_APP_NAME=

# ── Cloudflare Tunnel (optional) ──────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=
