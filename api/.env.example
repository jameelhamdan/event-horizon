# ── Core / Django ───────────────────────────────────────────────────────────────
SECRET_KEY=change-me
DEBUG=true
ENV_NAME=development
APP_NAME=eventhorizonai.dev
DOMAIN=localhost
CSRF_TRUSTED_ORIGINS=http://localhost
# Sentry (optional)
DSN=

# ── Database (MongoDB) ────────────────────────────────────────────────────────────
DATABASE_URL=mongodb://root:1234@localhost:27017/radar-live?authSource=admin

# ── Redis (Celery broker + cache) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Task queue ────────────────────────────────────────────────────────────────────
# false → tasks run synchronously in-process (no Redis/worker needed locally)
TASK_QUEUE_ENABLED=false

# ── Feature flags ─────────────────────────────────────────────────────────────────
# Set to false to disable a pipeline stage entirely (skipped in crontab + no-op if triggered).
NEWSLETTER_ENABLED=true
STREAM_PRICES_ENABLED=true
# aviationweather.gov removed NOTAM data entirely (Jul 2026) — leave false until
# services/streams/notam.py is rewritten against the FAA NOTAM API.
STREAM_NOTAM_ENABLED=false
STREAM_EARTHQUAKE_ENABLED=true
STREAM_FOREX_ENABLED=true
FORECAST_ENABLED=true
ARTICLE_IMPORTANCE_SCORING_ENABLED=true
# Optional egress proxy for Wayback Machine backfill requests (rate-limited per IP)
WAYBACK_PROXY_URL=

# ── Hugging Face Hub ──────────────────────────────────────────────────────────────
# Optional. Raises the anonymous rate limit and silences the "unauthenticated
# requests" warning when downloading/loading translation/FinBERT/cluster models.
# Read automatically by huggingface_hub/transformers — no code wiring needed.
# Get one at https://huggingface.co/settings/tokens (read-only scope is enough).
HF_TOKEN=

# ── LLM providers ─────────────────────────────────────────────────────────────────
# Routing (which provider handles which task) is configured in settings/base.py LLM_ROUTES.
# Model names and timeouts are also hardcoded there — only credentials and URLs go here.

# Ollama (self-hosted, no key) — run `ollama serve` + `ollama pull qwen3:14b`
OLLAMA_BASE_URL=http://localhost:11434

# Groq (free tier — https://console.groq.com) — comma-separated keys, rotated round-robin
GROQ_API_KEYS=

# Cerebras (free tier — https://cloud.cerebras.ai) — comma-separated keys
CEREBRAS_API_KEYS=

# OpenRouter (https://openrouter.ai) — comma-separated keys, rotated round-robin
OPENROUTER_API_KEYS=
OPENROUTER_MODELS=openrouter/free

# ── Email ─────────────────────────────────────────────────────────────────────────
# EMAIL_PROVIDER: smtp (default) or ses
EMAIL_PROVIDER=smtp
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=newsletter@localhost
NEWSLETTER_BASE_URL=http://localhost

# AWS SES (used when EMAIL_PROVIDER=ses)
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_KEY=
AWS_SES_REGION=us-east-1

# ── Frontend build args (ui/) ─────────────────────────────────────────────────────
VITE_GA_ID=
VITE_DOMAIN=
VITE_APP_NAME=

# ── Cloudflare Tunnel (optional) ──────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=
